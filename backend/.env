JWT_SECRET=change-me

# Comma-separated origins; use * only for local dev
CORS_ORIGINS=http://localhost:5173

LOG_LEVEL=debug
LOG_FILE=logs/app.log
LOG_MAX_SIZE=100
LOG_MAX_BACKUPS=10
LOG_MAX_AGE=30
LOG_COMPRESS=false
LOG_ENCRYPT=false
LOG_ENCRYPT_KEY=change-me
LOG_ENCRYPT_IV=change-me
LOG_ENCRYPT_ALGO=aes-256-cbc
LOG_ENCRYPT_MODE=cbc
LOG_ENCRYPT_PADDING=pkcs7